# /etc/helper/helper.env  (chmod 600 root:root)
# 非 wave 相关运行时变量。

ATHENAI_API_KEY=__FILL__
HELPER_ADMIN_SK=__GENERATE_RANDOM_64_CHAR__

HELPER_DATA_DIR=/var/lib/helper
HELPER_SPEC_GIT_DIR=/var/lib/helper/git-repo

# Inbox 周报 owner 域账号(每周一 09:00 CST 收 digest + 私聊回执批准/驳回 spec)
# 空 → 不启用 inbox_weekly 自动任务
HELPER_OWNER_DOMAIN=__FILL_DOMAIN_ACCOUNT__

LOG_LEVEL=info
