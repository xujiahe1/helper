# Local development env. Copy to .env and fill in.
# Server credentials live in /etc/helper/wave.env on the server, NOT here.

# Athenai LLM gateway
ATHENAI_API_KEY=sk-replace-me
ATHENAI_BASE_URL=https://athenai.mihoyo.com
# Anthropic-native endpoint: ${ATHENAI_BASE_URL}/v1/messages
# OpenAI-compat endpoint:    ${ATHENAI_BASE_URL}/v1/chat/completions

# Storage
HELPER_DATA_DIR=./var/helper
HELPER_SPEC_GIT_DIR=./var/helper/git-repo

# Wave IM (only when testing IM integration / deploying)
# Leave blank for local development without IM.
WAVE_APP_ID=
WAVE_APP_SECRET=
WAVE_CALLBACK_AES_KEY=
WAVE_CALLBACK_SIGN_TOKEN=
# Wave 开放平台 HTTP API base(出站发消息 / 反查域账号都打这个,不走 MCP)。
WAVE_OPEN_API_BASE_URL=https://open.hoyowave.com
# 默认米哈游租户(union_id ↔ 域账号互转用)。海外站换 ot_c45399c0727d26f53b481b26110866c6
WAVE_USER_TENANT_ID=ot_9c253a6cbabafcaf131ca0ab549049db

# Logging
LOG_LEVEL=INFO

# Admin endpoint protection. Generate with:
#   python3 -c "import secrets; print('sk-helper-' + secrets.token_urlsafe(32))"
# Leave blank during early dev — admin routes will return 404 instead of being exposed.
HELPER_ADMIN_SK=
